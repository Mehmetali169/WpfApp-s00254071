<Window x:Class="WpfApp_s00254071.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:WpfApp_s00254071"
        mc:Ignorable="d"
        Title="Club Management System - VERIFIED" Height="600" Width="1000"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- member list -->
        <GroupBox Header="All Members" Margin="5">
            <ListBox Name="lstMembers" SelectionChanged="lstMembers_SelectionChanged"/>
        </GroupBox>

        <!--details -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- members -->
            <GroupBox Header="Member Details" Margin="5">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Content="Member ID:" Grid.Row="0" Grid.Column="0" Margin="5"/>
                    <TextBlock Name="txtMemberId" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="5"/>

                    <Label Content="First Name:" Grid.Row="0" Grid.Column="2" Margin="5"/>
                    <TextBlock Name="txtFirstName" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="5"/>

                    <Label Content="Last Name:" Grid.Row="1" Grid.Column="0" Margin="5"/>
                    <TextBlock Name="txtSurname" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="5"/>

                    <Label Content="Date of Birth:" Grid.Row="1" Grid.Column="2" Margin="5"/>
                    <TextBlock Name="txtDob" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" Margin="5"/>

                    <Label Content="Contact No:" Grid.Row="2" Grid.Column="0" Margin="5"/>
                    <TextBlock Name="txtPhone" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="5"/>

                    <Label Content="Membership:" Grid.Row="2" Grid.Column="2" Margin="5"/>
                    <TextBlock Name="txtMembershipType" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" Margin="5"/>
                </Grid>
            </GroupBox>

            <!-- Traning  --> 
            <GroupBox Header="Training Sessions" Grid.Row="1" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Button Name="btnAddSession" Content="Add Training Session" HorizontalAlignment="Right" Margin="10" Click="btnAddSession_Click"/>

                    <ListBox Name="lstSessions" Grid.Row="1" Margin="5"/>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
